// two use statements importing from the same file:
// one selective (only users), one wildcard (everything)
// should result in all symbols being visible without duplicates
use { table users } from './single-source-tables.dbml'
use * from './single-source-tables.dbml'

Table memberships {
  id int [pk]
  user_id int
  role_id int
  kind user_role
}

Ref: memberships.user_id > users.id
Ref: memberships.role_id > roles.id

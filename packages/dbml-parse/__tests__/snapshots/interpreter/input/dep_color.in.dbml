Table users { id int }
Table orders { id int }
Table events { id int }
Table reports { id int }

// header attribute form
Dep dep_header [color: #aabbcc] {
  users -> orders
}

// body sub-declaration form
Dep dep_body {
  orders -> events
  color: #123456
}

// short / inline-setting form
Dep: users -> reports [color: #abcdef]

// uncolored, no color slot
Dep: events -> users
